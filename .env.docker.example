# ⚠️ IMPORTANTE: Este es un archivo de ejemplo
# 1. Copia este archivo a .env.docker:
#    cp .env.docker.example .env.docker
# 2. Rellena los valores con tus credenciales reales
# 3. Ejecuta: docker-compose --env-file .env.docker up -d

# ============================================
# BASE DE DATOS
# ============================================
DB_PASSWORD=tu_password_seguro_aqui_cambiar

# ============================================
# APIS DE GEOLOCALIZACIÓN
# ============================================
# Google Geolocation API (obtén tu key en: https://console.cloud.google.com/apis/credentials)
GOOGLE_GEOLOCATION_API_KEY=tu_google_api_key_aqui

# Unwired Labs Token (obtén en: https://unwiredlabs.com/)
UNWIRED_LABS_TOKEN=tu_unwired_labs_token_aqui

# OpenCellID Token (obtén en: https://opencellid.org/)
OPENCELLID_API_TOKEN=tu_opencellid_token_aqui

# ============================================
# SEGURIDAD
# ============================================
# JWT Secret (genera uno aleatorio con: openssl rand -base64 32)
JWT_SECRET=tu_jwt_secret_super_seguro_aqui_cambiar_en_produccion

# ============================================
# CONFIGURACIÓN DEL SERVIDOR
# ============================================
FRONTEND_URL=https://tu-dominio.com
SERVER_IP=tu-dominio.com
NODE_ENV=production
LOG_LEVEL=info
