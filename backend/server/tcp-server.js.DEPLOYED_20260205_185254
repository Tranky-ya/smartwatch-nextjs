      });
    } catch (error) {
      console.error('â‌Œ Error iniciando servidor TCP:', error);
      process.exit(1);
    }
  }

  

  handleConnection(socket) {
    const clientInfo = `${socket.remoteAddress}:${socket.remotePort}`;
    console.log(`ًں”Œ Nueva conexiأ³n desde ${clientInfo}`);

    let buffer = '';
    let currentDevice = null;
    const processMessage = this.processMessage.bind(this);

    socket.on('data', async (data) => {
      try {
        // ًں“¨ LOG RAW: Ver exactamente quأ© entra (con caracteres invisibles, \r, \n, espacios)
        const rawString = data.toString('utf8');
        console.log(`\nًں“¨ RAW [${clientInfo}] >>> ${JSON.stringify(rawString)}`);
        console.log(`   Bytes: [${Array.from(data).map(b => '0x' + b.toString(16).padStart(2, '0')).join(', ')}]`);
        
        buffer += rawString;

        // 1) Procesar frames del protocolo aunque vengan concatenados sin CR/LF:
        //    [..][..]\r\n  => se procesan ambos bloques.
        while (true) {
          const start = buffer.indexOf('[');
          if (start === -1) break;

          if (start > 0) {
            const junk = buffer.slice(0, start);
            if (junk.trim()) {
              console.warn(`âڑ ï¸ڈ [${clientInfo}] Bytes fuera de frame descartados: ${JSON.stringify(junk)}`);
            }
            buffer = buffer.slice(start);
          }

          const end = buffer.indexOf(']');
          if (end === -1) break; // frame incompleto, esperar mأ،s data

          const frame = buffer.slice(0, end + 1);
          buffer = buffer.slice(end + 1);

          const cleanedFrame = frame.trim();
          if (!cleanedFrame) continue;

          console.log(`ًں§¹ LIMPIO [${clientInfo}] >>> ${JSON.stringify(cleanedFrame)}`);
          console.log(`   Largo: ${cleanedFrame.length} caracteres`);
          console.log(`ًں§ھ [${clientInfo}] â–¶ VALIDANDO FORMATO...`);
          currentDevice = await processMessage(socket, cleanedFrame, currentDevice);
        }

        // 2) Procesar comandos/manuales por lأ­neas (telnet/hercules), si quedaron
        //    datos que NO son frames.
        if (buffer.includes('\n') || buffer.includes('\r')) {
          const parts = buffer.split(/[\r\n]+/);
          buffer = parts.pop() || '';

          for (const part of parts) {
            const cleaned = part.trim();
            if (!cleaned) continue;

            // Si parece inicio de frame incompleto, no lo consumas aquأ­.
            if (cleaned.startsWith('[') && !cleaned.includes(']')) {
              buffer = cleaned + buffer;
              continue;
            }

            console.log(`ًں§¹ LIMPIO [${clientInfo}] >>> ${JSON.stringify(cleaned)}`);
            console.log(`   Largo: ${cleaned.length} caracteres`);

            if (cleaned.toLowerCase() === 'exit' || cleaned.toLowerCase() === 'quit') {
              console.log(`ًںڑھ [${clientInfo}] Comando EXIT/QUIT manual recibido - cerrando conexiأ³n`);
              socket.end();
              return;
            }

            console.log(`ًں§ھ [${clientInfo}] â–¶ VALIDANDO FORMATO...`);
            currentDevice = await processMessage(socket, cleaned, currentDevice);
          }
        }
      } catch (error) {
        console.error(`â‌Œ Error procesando datos de ${clientInfo}:`, error.stack);
      }
    });

    socket.on('end', () => {
      if (currentDevice) {
        console.log(`ًں“´ [${currentDevice.imei}] Desconectado`);
        this.connections.delete(currentDevice.imei);
        currentDevice.update({ is_online: false }).catch(console.error);
      } else {
        console.log(`ًں“´ Desconectado ${clientInfo}`);
      }
    });

    socket.on('error', (error) => {
      console.error(`â‌Œ Error en conexiأ³n ${clientInfo}:`, error.message);
    });
  }

  async processMessage(socket, message, currentDevice) {
    try {
      console.log(`\nًں”چ [PARSE] Iniciando anأ،lisis de mensaje...`);
      
      const parsed = ProtocolParser.parse(message);

      if (!parsed) {
        console.warn(`â‌Œ [PARSE] Mensaje NO parseado/rechazado por validaciأ³n`);
        console.warn(`   Mensaje original: ${JSON.stringify(message)}`);
        return currentDevice;
      }

      console.log(`âœ… [PARSE] Mensaje parseado exitosamente`);
      console.log(`   Tipo: ${parsed.type}`);
      console.log(`   IMEI: ${parsed.imei}`);

      if (!String(parsed.imei || '').match(/^\d{10}$/)) {
        console.warn(`â‌Œ [PARSE] IMEI invأ،lido desde parser, descartando para evitar device fantasma`);
        console.warn(`   Tipo: ${parsed.type}, IMEI: ${JSON.stringify(parsed.imei)}, Mensaje: ${JSON.stringify(message)}`);
        return currentDevice;
      }

      let device = currentDevice;
      if (!device || device.imei !== parsed.imei) {
        console.log(`ًں”چ [DB] Buscando dispositivo ${parsed.imei} en BD...`);
        device = await Device.findOne({ where: { imei: parsed.imei } });
        
        if (!device) {
          console.warn(`âڑ ï¸ڈ [DB] Dispositivo ${parsed.imei} NO encontrado - Creando nuevo...`);
          device = await Device.create({
            imei: parsed.imei,
            name: `Device ${parsed.imei}`,
            organization_id: 'e5998eca-315a-44c6-a352-90d22380c5e8',
            is_online: true
          });
          console.log(`âœ… [DB] Dispositivo creado exitosamente`);
        } else {
          console.log(`âœ… [DB] Dispositivo encontrado en BD`);
        }

        this.connections.set(parsed.imei, socket);
      }

      console.log(`ًں”„ [DB] Actualizando estado: is_online=true, last_seen=${new Date().toISOString()}`);
      await device.update({
        is_online: true,
        last_seen: new Date()
      });

      console.log(`ًں“¨ [ROUTER] Ruteando al handler de tipo: ${parsed.type}`);

      switch (parsed.type) {
        case 'LK':
          await this.handleHeartbeat(device, parsed);
          break;
        case 'UD':
          await this.handlePosition(device, parsed);
          break;
        case 'AL':
          await this.handleAlarm(device, parsed);
          break;
        case 'bphrt':
          await this.handleHealthData(device, parsed);
          break;
        case 'CR':
          await this.handleCR(device, parsed);
          break;
        case 'HANDSHAKE':
          await this.handleHandshake(device, parsed);
          break;
      }

      // Generar respuesta segأ؛n el protocolo Beesure
      // âڑ ï¸ڈ IMPORTANTE:
      // - No responder a CR (eco)
      // - No responder a UNKNOWN
      // - No responder a UD (tracking); el reloj NO espera ACK
      if (parsed.type !== 'CR' && parsed.type !== 'UNKNOWN' && parsed.type !== 'UD') {
        const response = ProtocolParser.generateCommandResponse(device.imei, parsed.type);
        const responseWithNewline = response + '\n';
        
        console.log(`\nâœ… [RESPONSE] Respuesta generada`);
        console.log(`ًں“¤ [${device.imei}] Mensaje: ${JSON.stringify(response)}`);
        console.log(`ًں“¤ [${device.imei}] Con \\n: ${JSON.stringify(responseWithNewline)}`);
        console.log(`ًں“¤ [${device.imei}] Bytes: [${Array.from(Buffer.from(responseWithNewline)).map(b => '0x' + b.toString(16).padStart(2, '0')).join(', ')}]`);
        
        socket.write(responseWithNewline);
        console.log(`âœ… [${device.imei}] âœ“ Respuesta enviada exitosamente`);
      } else {
        console.log(`â„¹ï¸ڈ [${device.imei}] Sin respuesta para tipo: ${parsed.type}`);
      }

      // Notificar al WebSocket sobre la actualizaciأ³n del dispositivo
      if (this.websocketServer && parsed.type === 'LK') {
        this.websocketServer.emitHeartbeat(device);
      } else if (this.websocketServer && parsed.type === 'UD') {
        // Las posiciones se notifican en handlePosition()
      }

      return device;
    } catch (error) {
      console.error('â‌Œ Error procesando mensaje:', error);
      return currentDevice;
    }
  }

