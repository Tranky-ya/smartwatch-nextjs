  async handleAlarm(device, parsed) {
    try {
      const alarms = parsed.alarms;
      let alertType = 'UNKNOWN';
      let severity = 'MEDIUM';
      let message = 'Alarma desconocida';

      if (alarms.sos) {
        alertType = 'SOS';
        severity = 'CRITICAL';
        message = `ًں†ک Alerta SOS activada`;
      } else if (alarms.fallDown) {
        alertType = 'FALL_DOWN';
        severity = 'CRITICAL';
        message = `âڑ ï¸ڈ Caأ­da detectada`;
      } else if (alarms.lowBattery) {
        alertType = 'LOW_BATTERY';
        severity = 'LOW';
        message = `ًں”‹ Baterأ­a baja`;
      } else if (alarms.geofenceIn) {
        alertType = 'GEOFENCE_ENTER';
        severity = 'LOW';
        message = `ًں“چ Entrada a geocerca`;
      } else if (alarms.geofenceOut) {
        alertType = 'GEOFENCE_EXIT';
        severity = 'MEDIUM';
        message = `ًں“چ Salida de geocerca`;
      }

      await Alert.create({
        device_id: device.id,
        alert_type: alertType,
        severity: severity,
        message: message,
        latitude: parsed.latitude,
        longitude: parsed.longitude,
        metadata: { alarms: alarms, raw_type: parsed.alarmType },
        status: 'NEW',
        triggered_at: parsed.timestamp
