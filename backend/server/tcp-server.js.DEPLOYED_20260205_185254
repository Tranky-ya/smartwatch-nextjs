  /**
   * Envأ­a un comando al dispositivo a travأ©s de su socket TCP activo
   * @param {string} imei - IMEI del dispositivo
   * @param {string} command - Nombre del comando (IP, UPLOAD, CALL, etc.)
   * @param {object} params - Parأ،metros del comando
   * @returns {Promise<boolean>} true si se enviأ³ correctamente
   */
  async sendCommand(imei, command, params = {}) {
    try {
      const socket = this.connections.get(imei);
      
      if (!socket || socket.destroyed) {
        console.error(`â‌Œ [${imei}] No hay conexiأ³n activa para enviar comando`);
        return false;
      }

      const commandMessage = ProtocolParser.generateCommand(imei, command, params);
      const messageWithNewline = commandMessage + '\n';
      
      console.log(`\nًں“¤ [COMMAND] Enviando comando al dispositivo`);
      console.log(`   IMEI: ${imei}`);
      console.log(`   Comando: ${command}`);
      console.log(`   Parأ،metros: ${JSON.stringify(params)}`);
      console.log(`ًں“¤ [${imei}] Mensaje: ${JSON.stringify(commandMessage)}`);
      console.log(`ًں“¤ [${imei}] Con \\n: ${JSON.stringify(messageWithNewline)}`);
      console.log(`ًں“¤ [${imei}] Bytes: [${Array.from(Buffer.from(messageWithNewline)).map(b => '0x' + b.toString(16).padStart(2, '0')).join(', ')}]`);
      
      socket.write(messageWithNewline);
      console.log(`âœ… [${imei}] âœ“ Comando enviado exitosamente`);
      
      return true;
    } catch (error) {
      console.error(`â‌Œ Error enviando comando a ${imei}:`, error.stack);
