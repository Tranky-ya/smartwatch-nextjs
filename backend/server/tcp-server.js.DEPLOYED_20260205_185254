   */
  async changeServerIP(imei, ip, port) {
    console.log(`ًں”„ Iniciando cambio de servidor para ${imei}`);
    console.log(`   Destino: ${ip}:${port}`);
    
    return this.sendCommand(imei, 'IP', { ip, port });
  }

  /**
   * Envأ­a comando para configurar intervalo de carga
   * @param {string} imei - IMEI del dispositivo
   * @param {number} interval - Intervalo en segundos (60-65535)
   */
  async setUploadInterval(imei, interval) {
    if (interval < 60) interval = 60;
    if (interval > 65535) interval = 65535;
    
    return this.sendCommand(imei, 'UPLOAD', { interval });
  }

  /**
   * Envأ­a comando para solicitar ubicaciأ³n inmediata
   * @param {string} imei - IMEI del dispositivo
   */
  async requestLocation(imei) {
    return this.sendCommand(imei, 'CR', {});
  }

  /**
   * Envأ­a comando para reiniciar el dispositivo
   * @param {string} imei - IMEI del dispositivo
   */
  async rebootDevice(imei) {
    return this.sendCommand(imei, 'RESET', {});
  }

  /**
   * Envأ­a comando de bأ؛squeda (hace sonar el dispositivo)
   * @param {string} imei - IMEI del dispositivo
   */
  async findDevice(imei) {
    return this.sendCommand(imei, 'FIND', {});
  }

  stop() {
    if (this.server) {
      this.server.close();
      console.log('ًں›‘ Servidor TCP detenido');
    }
  }
}

module.exports = TCPServer;
