      console.log(`ًںڑ¨ [${device.imei}] ALARMA ${alertType} - ${message}`);

      if (this.websocketServer) {
        this.websocketServer.broadcast({
          type: 'alert',
          alert: {
            device_imei: device.imei,
            device_name: device.name,
            type: alertType,
