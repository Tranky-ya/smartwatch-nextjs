function extractFrames(buffer) {
  const frames = [];
  let current = '';
  let inside = false;

  for (const ch of buffer) {
    if (ch === '[') {
      inside = true;
      current = '[';
      continue;
    }

    if (inside) {
      current += ch;
    }

    if (ch === ']' && inside) {
      frames.push(current);
      current = '';
      inside = false;
    }
  }

  return frames;
}

class TCPServer extends EventEmitter {
