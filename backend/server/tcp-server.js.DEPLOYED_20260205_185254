    this.port = port || process.env.TCP_SERVER_PORT || 7070;
    this.server = null;
    this.connections = new Map();
    this.websocketServer = websocketServer;
    
    // Inicializar motor hأ­brido de localizaciأ³n
    this.locationEngine = new HybridLocationEngine({
      googleApiKey: process.env.GOOGLE_GEOLOCATION_API_KEY,
      opencellIdToken: process.env.OPENCELLID_API_TOKEN,
      smoothingAlpha: parseFloat(process.env.SMOOTHING_ALPHA) || 0.25,
      maxJumpMeters: parseInt(process.env.MAX_JUMP_METERS) || 40,
      maxSpeedKmh: parseInt(process.env.MAX_SPEED_KMH) || 15,
      stationaryTimeSeconds: parseInt(process.env.STATIONARY_TIME_SECONDS) || 30,
      cacheTTLMinutes: parseInt(process.env.CACHE_TTL_MINUTES) || 60,
      mapMatchingEnabled: process.env.MAP_MATCHING_ENABLED === "true",
      logLevel: process.env.LOG_LEVEL || "info"
    });
    console.log("âœ… Motor Hأ­brido de Localizaciأ³n inicializado");
  }

  setWebSocketServer(websocketServer) {
    this.websocketServer = websocketServer;
    console.log('âœ… WebSocket Server vinculado al TCP Server');
  }

  async start() {
    try {
      await testConnection();
      this.server = net.createServer((socket) => {
        this.handleConnection(socket);
      });

      this.server.listen(this.port, this.host, () => {
